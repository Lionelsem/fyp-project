rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    match /inspection-defect-photos/{allPaths=**} {
      allow read, write: if request.auth != null;
    }

    match /closure-verifications/{allPaths=**} {
      allow read, write: if request.auth != null;
    }

    match /inspectionReports/{allPaths=**} {
      allow read, write: if request.auth != null;
    }

    match /fire-drills/{allPaths=**} {
      allow read, write: if request.auth != null;
    }
  }
}
